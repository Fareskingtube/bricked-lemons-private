enum Role {
  USER
  ADMIN
}

model User {
  id String @id @default(uuid())
  username String 
  email String @unique
  password String
  role Role @default(USER)
  // reviews Review[]

  createdAt DateTime @default(now())
}

model Product {
  id        String      @id @default(uuid())
  name      String
  price     Float
  category  String
  imageLink String
  // reviews Review[]

  reviewRating Int @default(0)
  reviewCount  Int @default(0)
  createdAt DateTime @default(now())
}