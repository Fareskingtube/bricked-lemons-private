{
	"name": "bricked-lemons",
	"version": "1.0.0",
	"license": "LGPL-2.1",
	"author": "Fareskingtube",
	"repository": "github:Fareskingtube/bricked-lemons",
	"type": "module",
	"main": "index.js",
	"scripts": {
		"dev": "nodemon",
		"build": "tsc",
		"start": "node build/index.js",
		"lint": "eslint .",
		"test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathIgnorePatterns=integration --testPathIgnorePatterns=msw",
		"test:integration": "dotenv -e .env -- node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPatterns=integration --runInBand",
		"test:msw": "node --experimental-vm-modules node_modules/jest/bin/jest.js src/tests/products.msw.spec.ts",
		"generate:pg": "npx prisma generate --schema=./prisma/postgres/schema.prisma",
		"generate:mongo": "npx prisma generate --schema=./prisma/mongo/schema.prisma",
		"generate": "npm run generate:pg && npm run generate:mongo",
		"migrate:pg": "npx prisma migrate dev --schema=./prisma/postgres/schema.prisma",
		"migrate:mongo": "npx prisma db push dev --schema=./prisma/mongo/schema.prisma",
		"migrate": "npm run migrate:pg && npm run migrate:mongo",
		"seed:pg": "tsx prisma/postgres/seed.ts"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@jest/globals": "^30.4.1",
		"@swc/core": "^1.15.43",
		"@swc/jest": "^0.2.39",
		"@types/bcrypt": "^6.0.0",
		"@types/cookie-parser": "^1.4.10",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/jest": "^30.0.0",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/multer": "^2.2.0",
		"@types/node": "^26.1.1",
		"@types/nodemailer": "^8.0.1",
		"@types/pg": "^8.20.0",
		"@types/supertest": "^7.2.0",
		"dotenv": "^17.4.2",
		"dotenv-cli": "^11.0.0",
		"eslint": "^10.6.0",
		"jest": "^30.4.2",
		"jest-mock-extended": "^4.0.1",
		"msw": "^2.15.0",
		"nodemon": "^3.1.14",
		"supertest": "^7.2.2",
		"ts-jest": "^29.4.11",
		"ts-node": "^10.9.2",
		"tsx": "^4.23.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.63.0",
		"vitest": "^4.1.10"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1090.0",
		"@aws-sdk/s3-request-presigner": "^3.1090.0",
		"@prisma/client": "6.19.0",
		"bcrypt": "^6.0.0",
		"cookie-parser": "^1.4.7",
		"cors": "^2.8.6",
		"express": "^5.2.1",
		"jsonwebtoken": "^9.0.3",
		"multer": "^2.2.0",
		"nodemailer": "^9.0.3",
		"pg": "^8.22.0",
		"prisma": "6.19.0"
	}
}
